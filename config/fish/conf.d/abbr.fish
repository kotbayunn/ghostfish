# ── Аббревиатуры ─────────────────────────────────────────────
# В отличие от алиасов, abbr раскрываются прямо в строке ввода
# (нажми пробел/Enter) — видно полную команду в истории.

# git
abbr -a gs   git status
abbr -a ga   git add
abbr -a gc   git commit
abbr -a gca  git commit -a
abbr -a gco  git checkout
abbr -a gp   git push
abbr -a gl   git pull
abbr -a gd   git diff
abbr -a glog git log --oneline --graph --decorate

# навигация
abbr -a ..   cd ..
abbr -a ...  cd ../..
abbr -a .... cd ../../..

# прочее
abbr -a c    clear
